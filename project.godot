; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Pixel Péril"
config/description="Jeu dont le but est d'esquiver les ennemies, plus tu survis plusle score augmente !"
config/version="1.7"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "Mobile")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/image="res://art/load_screen.png"
config/icon="res://art/logo-128x128.png"
config/macos_native_icon="res://art/logo.icns"
config/windows_native_icon="res://art/logo-128x128.ico"
boot_splash/minimum_display_time=4000

[autoload]

GameData="*res://game_data.gd"

[display]

window/size/viewport_width=520
window/size/viewport_height=940
window/size/initial_position=Vector2i(600, 350)
window/stretch/mode="canvas_items"
display_server/driver.android="android"
window/handheld/orientation=1
mouse_cursor/custom_image="res://art/cursor.png"

[input]

move_right={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194321,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
, null]
}
move_left={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194319,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
